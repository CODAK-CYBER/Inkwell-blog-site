# Copy to .env and fill in. See README for details.

DATABASE_URL="file:./dev.db"

# Generate with: npx @better-auth/cli secret  (or any 32+ char random string)
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email (https://resend.com) — empty means dev mode: emails print to terminal
RESEND_API_KEY=""
EMAIL_FROM="Inkwell <no-reply@yourdomain.com>"

# Flutterwave payments (https://dashboard.flutterwave.com → Settings → API Keys)
# Empty = dev checkout: memberships/donations activate instantly without charging.
FLUTTERWAVE_SECRET_KEY=""
# Webhook verification: any random string; set the SAME value in
# Flutterwave dashboard → Settings → Webhooks (URL: {BETTER_AUTH_URL}/api/payments/webhook)
FLUTTERWAVE_SECRET_HASH=""
# Currency for plans/donations — NGN, USD, GHS, KES, ZAR… (must be enabled on your account)
PAYMENT_CURRENCY="USD"

# OAuth apps — empty hides that provider's button
# Google: https://console.cloud.google.com/apis/credentials  (redirect: {BETTER_AUTH_URL}/api/auth/callback/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub: https://github.com/settings/developers  (callback: {BETTER_AUTH_URL}/api/auth/callback/github)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Apple (requires paid developer account)
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
