// Inkwell database schema.
//
// Dev runs on SQLite; production targets PostgreSQL (Neon/Supabase).
// Kept portable: no enums (SQLite doesn't support them) — allowed values
// live in src/lib/constants.ts — and JSON blobs are stored as strings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// Auth core (shape required by better-auth + its plugins)
// ------------------------------------------------------------------

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // username plugin
  username        String? @unique
  displayUsername String?

  // admin plugin
  role       String?   @default("user")
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  // twoFactor plugin
  twoFactorEnabled Boolean? @default(false)

  // Profile
  bio         String?
  website     String?
  location    String?
  coverImage  String?
  socialLinks String? // JSON: { twitter, github, linkedin, ... }
  language    String  @default("en")
  timezone    String  @default("UTC")

  // Trust & verification
  verified Boolean @default(false)

  // Preferences
  profileVisibility     String  @default("public") // public | private
  showReadingActivity   Boolean @default(true)
  preferredContentTypes String? // JSON: ["articles","videos","podcasts"]
  emailFrequency        String  @default("weekly") // daily | weekly | monthly | none
  onboardingComplete    Boolean @default(false)

  articles           Article[]
  activityLogs       ActivityLog[]
  searchHistory      SearchHistory[]
  comments           Comment[]
  commentReactions   CommentReaction[]
  notifications      Notification[]
  reportsMade        Report[] @relation("reporter")
  sessions           Session[]
  accounts           Account[]
  twoFactors         TwoFactor[]
  interests          UserInterest[]
  follows            Follow[]
  bookmarks          Bookmark[]
  likes              Like[]
  readingHistory     ReadingHistory[]
  readingLists       ReadingList[]
  loginEvents        LoginEvent[]
  notificationPrefs  NotificationPreferences?
  badges             UserBadge[]
  subscriptions      Subscription[]
  loyaltyTransactions LoyaltyTransaction[]
  referralsMade      Referral[] @relation("referrer")
  referralReceived   Referral?  @relation("referred")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // admin plugin
  impersonatedBy String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("twoFactor")
}

// ------------------------------------------------------------------
// Content (articles, categories, tags)
// ------------------------------------------------------------------

model Category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  description    String?
  icon           String? // emoji or icon name
  image          String?
  sortOrder      Int        @default(0)
  parentId       String?
  parent         Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[] @relation("CategoryTree")
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime   @default(now())
  articles       Article[]

  @@map("category")
}

model Tag {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  articles  ArticleTag[]

  @@map("tag")
}

// Article.status pipeline: draft → pending → needs_revision ⇄ fact_check →
// seo_review → approved → scheduled → published → archived | trashed
model Article {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String
  content        String // markdown
  coverImage     String?
  status         String    @default("draft")
  featured       Boolean   @default(false)
  pinned         Boolean   @default(false)
  isBreaking     Boolean   @default(false)
  isPremium      Boolean   @default(false)
  isSponsored    Boolean   @default(false)
  engagementEnabled Boolean @default(true)
  allowComments  Boolean   @default(true)
  views          Int       @default(0)
  readingTime    Int       @default(1)
  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?
  focusKeyword   String?
  publishedAt    DateTime?
  scheduledFor   DateTime?
  expiresAt      DateTime? // auto-unpublish after this moment
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  authorId   String
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  tags          ArticleTag[]
  viewEvents    ViewEvent[]
  collections   CollectionItem[]
  versions      ArticleVersion[]
  statusHistory ArticleStatusHistory[]
  mediaUsage    MediaUsage[]
  comments      Comment[]

  @@index([status, publishedAt])
  @@index([authorId])
  @@index([categoryId])
  @@map("article")
}

// Snapshot of an article's content each time it is saved (capped per article).
model ArticleVersion {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  title     String
  excerpt   String
  content   String
  editorId  String?
  createdAt DateTime @default(now())

  @@index([articleId, createdAt])
  @@map("article_version")
}

model ArticleStatusHistory {
  id         String   @id @default(cuid())
  articleId  String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  fromStatus String
  toStatus   String
  userId     String?
  note       String?
  createdAt  DateTime @default(now())

  @@index([articleId, createdAt])
  @@map("article_status_history")
}

// ------------------------------------------------------------------
// Digital Asset Management
// ------------------------------------------------------------------

model MediaFolder {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  media     Media[]

  @@map("media_folder")
}

// Media.kind: image | video | audio | document
model Media {
  id         String       @id @default(cuid())
  filename   String // original filename
  url        String // public URL (local path or Cloudinary)
  kind       String
  mimeType   String
  size       Int // bytes
  width      Int?
  height     Int?
  hash       String // sha256 of contents — duplicate detection
  alt        String?
  caption    String?
  credit     String? // copyright / attribution
  tags       String? // comma-separated
  favorite   Boolean      @default(false)
  deletedAt  DateTime? // soft delete ("trash")
  folderId   String?
  folder     MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploaderId String?
  createdAt  DateTime     @default(now())
  usage      MediaUsage[]

  @@index([kind, deletedAt])
  @@index([hash])
  @@map("media")
}

// Which articles reference which assets — synced on every article save.
model MediaUsage {
  mediaId   String
  media     Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  field     String  @default("content") // content | cover

  @@id([mediaId, articleId, field])
  @@map("media_usage")
}

// One row per page view — powers trending + audience analytics.
model ViewEvent {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String? // no FK: kept anonymous-ish for analytics
  userAgent String?
  referrer  String?
  language  String?
  createdAt DateTime @default(now())

  @@index([articleId, createdAt])
  @@index([createdAt])
  @@map("view_event")
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  results   Int? // result count — zero-result queries feed search intelligence
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([query])
  @@map("search_history")
}

// Curated cross-category content hubs (e.g. "AI Special Report")
model Collection {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  coverImage  String?
  featured    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  items       CollectionItem[]

  @@map("collection")
}

model CollectionItem {
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  articleId    String
  article      Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)

  @@id([collectionId, articleId])
  @@map("collection_item")
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tag")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // e.g. article.published, user.banned, category.created
  targetType String?
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@map("activity_log")
}

// ------------------------------------------------------------------
// Personalization (powers Phase 3)
// ------------------------------------------------------------------

model UserInterest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     String // category slug, e.g. "technology"
  createdAt DateTime @default(now())

  @@unique([userId, topic])
  @@map("user_interest")
}

model Follow {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String // author | category | tag
  targetKey  String // slug or id of the followed entity
  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetKey])
  @@index([targetType, targetKey])
  @@map("follow")
}

// ------------------------------------------------------------------
// Saved content & engagement
// ------------------------------------------------------------------

model Bookmark {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleSlug String
  archived    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  listId      String?
  list        ReadingList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  @@unique([userId, articleSlug])
  @@map("bookmark")
}

// One reaction per user per article; `type` distinguishes like/love/insightful/…
model Like {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleSlug String
  type        String   @default("like") // like | love | insightful | funny | celebrate
  createdAt   DateTime @default(now())

  @@unique([userId, articleSlug])
  @@index([articleSlug])
  @@map("like")
}

model ReadingHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleSlug String
  readAt      DateTime @default(now())
  progress    Float    @default(0) // 0..1 scroll progress

  @@unique([userId, articleSlug])
  @@index([userId, readAt])
  @@map("reading_history")
}

model ReadingList {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isPublic    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  bookmarks   Bookmark[]

  @@map("reading_list")
}

// ------------------------------------------------------------------
// Security & notifications
// ------------------------------------------------------------------

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("login_event")
}

model NotificationPreferences {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled   Boolean @default(true)
  inAppEnabled   Boolean @default(true)
  pushEnabled    Boolean @default(false)
  weeklyDigest   Boolean @default(true)
  breakingNews   Boolean @default(false)
  newFollower    Boolean @default(true)
  newLoginAlert  Boolean @default(true)
  categoryTopics String? // JSON: category slugs to notify about

  @@map("notification_preferences")
}

// ------------------------------------------------------------------
// Community (Phase 7)
// ------------------------------------------------------------------

// Comment.status: visible | flagged (word filter / reported, hidden) | hidden (moderator)
model Comment {
  id         String    @id @default(cuid())
  articleId  String
  article    Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentThread")
  content    String
  status     String    @default("visible")
  pinned     Boolean   @default(false)
  isOfficial Boolean   @default(false) // staff response marker
  editedAt   DateTime?
  createdAt  DateTime  @default(now())

  reactions CommentReaction[]

  @@index([articleId, createdAt])
  @@index([status])
  @@map("comment")
}

model CommentReaction {
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([commentId, userId])
  @@map("comment_reaction")
}

// Report.targetType: comment | article | user; status: open | resolved | dismissed
model Report {
  id           String    @id @default(cuid())
  reporterId   String
  reporter     User      @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType   String
  targetId     String
  reason       String
  detail       String?
  status       String    @default("open")
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([status, createdAt])
  @@map("report")
}

// ------------------------------------------------------------------
// Communication (Phase 8)
// ------------------------------------------------------------------

// Notification.priority: critical | high | medium | low
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // new_article | breaking | reply | mention | follower | achievement | announcement | security
  title     String
  body      String?
  url       String?
  priority  String   @default("medium")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
  @@map("notification")
}

// Announcement.level: info | warning | critical; audience: all | premium | authors | staff
model Announcement {
  id         String    @id @default(cuid())
  title      String
  body       String
  level      String    @default("info")
  audience   String    @default("all")
  showBanner Boolean   @default(true)
  active     Boolean   @default(true)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([active, createdAt])
  @@map("announcement")
}

// ------------------------------------------------------------------
// Platform operations (Phase 9)
// ------------------------------------------------------------------

// Key-value platform configuration (maintenance mode, feature toggles, branding)
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_setting")
}

// Internal staff notes on a user (never shown to the user)
model UserNote {
  id        String   @id @default(cuid())
  userId    String
  authorId  String?
  note      String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("user_note")
}

// Formal warnings (user is notified)
model UserWarning {
  id         String   @id @default(cuid())
  userId     String
  issuedById String?
  reason     String
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@map("user_warning")
}

// ------------------------------------------------------------------
// Monetization (Phase 10)
// ------------------------------------------------------------------

// Ad.placement: home_banner | article_bottom
model Ad {
  id          String    @id @default(cuid())
  name        String
  placement   String
  imageUrl    String?
  html        String? // custom embed (admin-entered, trusted)
  targetUrl   String?
  weight      Int       @default(1) // rotation weighting
  active      Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  impressions Int       @default(0)
  clicks      Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([placement, active])
  @@map("ad")
}

// Cloaked affiliate links: /go/{code} → targetUrl (click-tracked)
model AffiliateLink {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  targetUrl String
  clicks    Int      @default(0)
  createdAt DateTime @default(now())

  @@map("affiliate_link")
}

model Donation {
  id        String   @id @default(cuid())
  userId    String?
  name      String? // display name for anonymous/guest donors
  amount    Int // cents
  message   String?
  provider  String   @default("dev") // dev | flutterwave
  txRef     String?  @unique // payment reference — webhook/callback idempotency
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("donation")
}

// ------------------------------------------------------------------
// Future-proofing (Phases 3, 7, 10): dormant until those phases land
// ------------------------------------------------------------------

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  icon        String?
  users       UserBadge[]

  @@map("badge")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badge")
}

model Subscription {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              String // free | premium_monthly | premium_yearly
  status            String // active | canceled | past_due | trialing
  provider          String? // flutterwave | dev | comp
  providerCustomerId String?
  currentPeriodEnd  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@map("subscription")
}

model LoyaltyTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points    Int
  reason    String // read_streak | referral | comment | ...
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("loyalty_transaction")
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referrer       User     @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String?  @unique
  referredUser   User?    @relation("referred", fields: [referredUserId], references: [id], onDelete: SetNull)
  code           String   @unique
  createdAt      DateTime @default(now())

  @@map("referral")
}
